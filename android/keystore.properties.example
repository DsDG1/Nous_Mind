# Template for android/keystore.properties (the real file is gitignored).
# Copy this file to `keystore.properties` and fill in the values for your
# release keystore. Gradle will pick it up automatically; if it is absent
# the release build falls back to debug signing.
#
# Paths in `storeFile` are resolved relative to android/app/.

storeFile=nousmind-release.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=YOUR_KEY_ALIAS
keyPassword=YOUR_KEY_PASSWORD
